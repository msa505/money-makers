# 依赖 / 构建产物（各项目统一忽略，避免污染仓库）
node_modules/
dist/
build/
.next/
out/
__pycache__/
*.pyc
.venv/
venv/
target/
vendor/

# 大文件 / 模型权重（如含模型建议走 Git LFS 或单独存放）
*.bin
*.onnx
*.gguf
*.pt
*.ckpt

# 系统 / 编辑器
.DS_Store
.idea/
.vscode/
*.log

# 环境配置文件（含密钥，禁止入库；仅保留 .example/.sample/.template 模板）
.env
.env.*
!.env.example
!.env.sample
!.env.template

# 超大文件（超过 GitHub 推荐 50MB，建议改走 Git LFS，避免污染普通 clone）
*.gif
